---
import BaseLayout from '~/layouts/BaseLayout.astro'
import { tools, categoryLabels } from '~/lib/toolMeta'
import {
  Minimize2,
  Maximize2,
  Crop,
  ArrowRightLeft,
  ImageIcon,
  Paintbrush,
  Sparkles,
  Eraser,
  Droplets,
  Laugh,
  RotateCw,
  Code,
  ScanFace,
} from 'lucide-react'

const iconMap: Record<string, any> = {
  Minimize2, Maximize2, Crop, ArrowRightLeft, ImageIcon, Paintbrush,
  Sparkles, Eraser, Droplets, Laugh, RotateCw, Code, ScanFace,
}

function getIconComponent(iconName: string) {
  return iconMap[iconName] || null
}

const categories = ['image', 'convert', 'edit', 'ai'] as const
---

<BaseLayout
  title="Image Tools — compress, convert, resize in your browser"
  description="14 free image tools that run 100% in your browser. Compress, resize, crop, convert (HEIC/WEBP/JPG/PNG), watermark, rotate, upscale with AI, remove backgrounds, blur faces, and generate memes — your photos never leave your device."
>
  <section class="hero container-page">
    <p class="eyebrow">🖼️ image.oriz.in</p>
    <h1>Image tools that respect your privacy</h1>
    <p class="lede">
      14 free tools — compress, resize, crop, convert, watermark, rotate, AI
      upscale, background removal, face blur, meme generator, and more. Every
      operation runs locally in your browser. Your photos never travel over
      the network.
    </p>
    <div class="hero-cta">
      <a href="#tools" class="btn-primary">Browse tools</a>
      <a href="/about/" class="btn-secondary">How it works</a>
    </div>
  </section>

  <section class="features container-page">
    <div class="feature">
      <h3>100% private</h3>
      <p>Browser-only. No uploads, no servers, no analytics on your images.</p>
    </div>
    <div class="feature">
      <h3>No sign-up</h3>
      <p>Pick a tool and go. Optional sign-in syncs preferences across the family.</p>
    </div>
    <div class="feature">
      <h3>Lightning fast</h3>
      <p>WebAssembly + Canvas APIs. No upload/download wait, even for 50 MP photos.</p>
    </div>
    <div class="feature">
      <h3>Free forever</h3>
      <p>Static site, no servers to bill for, no premium tier, no watermarks.</p>
    </div>
  </section>

  <section id="tools" class="tools-section container-page">
    <header class="section-head">
      <h2>All tools</h2>
      <p>Pick one. Every tool processes your images locally in your browser.</p>
    </header>

    {categories.map((cat) => (
      <div class="cat-block">
        <h3 class="cat-h">{categoryLabels[cat] || cat}</h3>
        <div class="tool-grid">
          {tools.filter((t) => t.category === cat).map((tool) => {
            const Icon = getIconComponent(tool.icon.name)
            return (
              <a href={tool.href} class="tool-card group">
                <div class="tool-card-head">
                  <div class="tool-icon-wrap">
                    {Icon && <Icon size={20} aria-hidden="true" />}
                  </div>
                  <h4 class="tool-name">{tool.name}</h4>
                  {tool.isNew && <span class="badge-new">NEW</span>}
                </div>
                <p class="tool-desc">{tool.description}</p>
              </a>
            )
          })}
        </div>
      </div>
    ))}
  </section>

  <section class="how container-page">
    <h2>How it works</h2>
    <ol class="how-steps">
      <li><strong>Upload</strong> — drop images or click to browse.</li>
      <li><strong>Process</strong> — adjust settings; everything runs in your browser.</li>
      <li><strong>Download</strong> — get individual files or a single ZIP.</li>
    </ol>
  </section>

  <section class="faq container-page">
    <h2>Questions</h2>
    <details>
      <summary>Is this really free?</summary>
      <p>Yes. No premium tier, no watermarks, no per-image limits.</p>
    </details>
    <details>
      <summary>Are my images secure?</summary>
      <p>100%. All processing happens in your browser. We never see or store your images.</p>
    </details>
    <details>
      <summary>What formats are supported?</summary>
      <p>JPG, PNG, GIF, WEBP, HEIC, TIFF, SVG. Each tool's "accept" list shows what it takes.</p>
    </details>
    <details>
      <summary>Can I batch-process?</summary>
      <p>Most tools accept up to 20 images at once and download as a ZIP.</p>
    </details>
    <details>
      <summary>Do I need an account?</summary>
      <p>No. Optional sign-in carries preferences across <a href="https://oriz.in">other oriz sites</a>.</p>
    </details>
  </section>
</BaseLayout>

<style>
  .hero { padding-block: 3rem 2rem; }
  .eyebrow { color: var(--color-fg-muted); font-size: 0.875rem; margin: 0 0 0.75rem; }
  .hero h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    max-width: 18ch;
  }
  .lede {
    color: var(--color-fg-muted);
    margin: 1rem 0 1.5rem;
    max-width: 60ch;
    font-size: 1.0625rem;
    line-height: 1.6;
  }
  .hero-cta { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
    padding-block: 2rem 3rem;
    border-block: 1px solid var(--color-border);
  }
  .feature h3 {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    font-weight: 600;
    margin: 0 0 0.375rem;
  }
  .feature p { color: var(--color-fg-muted); font-size: 0.9375rem; margin: 0; }

  .tools-section { padding-block: 3rem; }
  .section-head h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0 0 0.5rem;
  }
  .section-head p { color: var(--color-fg-muted); margin: 0 0 2rem; }
  .cat-block { margin-bottom: 2.5rem; }
  .cat-h {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-fg-muted);
    margin: 0 0 1rem;
    font-weight: 600;
  }
  .tool-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }
  .tool-card-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  .tool-icon-wrap {
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-muted);
    border-radius: var(--radius-button);
    color: var(--color-fg);
  }
  .tool-card:hover .tool-icon-wrap { color: var(--color-accent); }
  .tool-name {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
    flex: 1;
  }
  .tool-desc {
    color: var(--color-fg-muted);
    font-size: 0.875rem;
    margin: 0;
    line-height: 1.5;
  }

  .how, .faq { padding-block: 3rem; }
  .how h2, .faq h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    margin: 0 0 1.5rem;
  }
  .how-steps {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: step;
  }
  .how-steps li {
    counter-increment: step;
    padding: 1.25rem;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    color: var(--color-fg-muted);
    position: relative;
  }
  .how-steps li::before {
    content: counter(step);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: var(--color-accent);
    color: var(--color-accent-fg);
    border-radius: 9999px;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .how-steps strong { color: var(--color-fg); display: block; }

  .faq details {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    background: var(--color-bg-soft);
    margin-bottom: 0.5rem;
    padding: 0 1rem;
  }
  .faq summary {
    cursor: pointer;
    padding: 1rem 0;
    font-weight: 500;
    color: var(--color-fg);
  }
  .faq details[open] summary { border-bottom: 1px solid var(--color-border); }
  .faq details p {
    color: var(--color-fg-muted);
    padding: 1rem 0;
    margin: 0;
  }
</style>
