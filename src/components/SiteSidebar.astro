---
/**
 * SiteSidebar — left rail for Image Tools. Mirrors the tool catalog from
 * `~/lib/toolMeta` plus a Family quick-jump (built from FAMILY_SITES).
 *
 * The actual rendering is delegated to oriz-ui's <Sidebar /> React island so
 * the styling, mobile sheet, and a11y stay consistent across every site.
 */
import { Sidebar, FAMILY_SITES, type SidebarSection } from '@chirag127/oriz-ui'
import { tools } from '~/lib/toolMeta'

const toolsByCategory = tools.reduce<Record<string, { label: string; href: string }[]>>(
  (acc, t) => {
    if (!acc[t.category]) acc[t.category] = []
    acc[t.category].push({ label: t.name, href: t.href })
    return acc
  },
  {},
)

const categoryLabel: Record<string, string> = {
  image: 'Image',
  convert: 'Convert',
  edit: 'Edit',
  ai: 'AI',
}

const sections: SidebarSection[] = [
  { title: 'Browse', links: [
    { label: 'All tools', href: '/tools/' },
    { label: 'Blog', href: '/blog/' },
    { label: 'About', href: '/about/' },
  ] },
  ...Object.entries(toolsByCategory).map(([cat, links]) => ({
    title: categoryLabel[cat] ?? cat,
    links,
  })),
  { title: 'Family', links: FAMILY_SITES.map((s) => ({ label: `${s.emoji} ${s.name}`, href: s.url })) },
]
---

<Sidebar
  client:idle
  siteName="Image Tools"
  siteSlug="image-tools"
  sections={sections}
/>
