---
/**
 * BaseLayout — every page on image.oriz.in extends this. Pulls the oriz-ui
 * design tokens via global.css, pre-paints the theme + accent from
 * localStorage, mounts a sticky Header + a left SiteSidebar (collapsible on
 * mobile) + a Footer, and conditionally injects the AdSense, GA4, and
 * Cloudflare Web Analytics scripts.
 */
import '~/styles/global.css'
import preflight from '~/lib/preflight.js?raw'
import Header from '~/components/Header.astro'
import Footer from '~/components/Footer.astro'
import SiteSidebar from '~/components/SiteSidebar.astro'
import { SITE_CONFIG } from '~/lib/siteConfig'

interface Props {
  title?: string
  description?: string
  canonical?: string
  noindex?: boolean
  jsonLd?: Record<string, unknown> | Record<string, unknown>[]
  /** Hide the left sidebar (default false). Useful for landing-style pages. */
  hideSidebar?: boolean
}

const {
  title = `${SITE_CONFIG.name} — ${SITE_CONFIG.tagline}`,
  description = SITE_CONFIG.description,
  canonical = `${SITE_CONFIG.origin}${Astro.url.pathname}`,
  noindex = false,
  jsonLd,
  hideSidebar = false,
} = Astro.props

const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT
const beaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN
const ga4Id = import.meta.env.PUBLIC_GA4_ID
---

<!doctype html>
<html lang="en" data-theme="dark" data-accent="amber">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_CONFIG.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@chirag127" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:ital,wght@0,400;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <script is:inline set:html={preflight} />

    {jsonLd && (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify(Array.isArray(jsonLd) ? jsonLd : [jsonLd])}
      />
    )}

    {adsenseClient && (
      <script
        is:inline
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
        crossorigin="anonymous"
      />
    )}

    {beaconToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${beaconToken}"}`}
      />
    )}

    {ga4Id && (
      <>
        <script
          is:inline
          async
          src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}
        />
        <script
          is:inline
          set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments)}gtag('js',new Date());gtag('config','${ga4Id}');`}
        />
      </>
    )}
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <div class={`page-shell ${hideSidebar ? 'no-sidebar' : ''}`}>
      {!hideSidebar && <SiteSidebar />}
      <main id="main"><slot /></main>
    </div>
    <Footer />

    <style is:global>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--color-accent);
        color: var(--color-accent-fg);
        padding: 0.5rem 1rem;
        z-index: 100;
        border-radius: 0 0 0.5rem 0;
      }
      .skip-link:focus { left: 0; }

      .page-shell { display: block; }
      @media (min-width: 1024px) {
        .page-shell:not(.no-sidebar) {
          display: grid;
          grid-template-columns: 240px minmax(0, 1fr);
          gap: 0;
          align-items: start;
        }
        .page-shell:not(.no-sidebar) > main { min-width: 0; }
      }
    </style>
  </body>
</html>
