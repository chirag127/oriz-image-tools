---
/**
 * Legacy `Base.astro` — kept as a thin shim that forwards into BaseLayout so
 * the existing tool, blog, about, contact, privacy, terms, and tools/index
 * pages don't all need to be rewritten. New pages should import BaseLayout
 * directly.
 */
import BaseLayout from '~/layouts/BaseLayout.astro'

interface Props {
  title: string
  description: string
  canonical?: string
}

const { title, description, canonical } = Astro.props
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <slot />
</BaseLayout>
